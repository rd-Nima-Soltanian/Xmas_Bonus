{
  "name": "Xmas_Bonus",
  "version": "1.0.0",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-mass-edit-xmas": "cds watch --open rewe.hcm.masseditxmas/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-mass-edit-xmas-bonus": "cds watch --open rewe.hcm.masseditxmasbonus/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "SFv2": {
        "kind": "odata-v2",
        "model": "srv/external/SFv2",
        "credentials": {
          "destination": "sap-successfactors-extensibility--api-access--tu",
          "path": "/odata/v2/"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ]
}
